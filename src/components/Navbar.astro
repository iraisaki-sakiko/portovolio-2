---
// Navbar.astro - Responsive navigation dengan interaksi ringan
const currentPage = Astro.url.pathname;
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-white/80 dark:bg-black/80 border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      {/* Logo / Brand */}
      <a href="/" class="text-xl font-bold bg-gradient-to-r from-red-600 to-red-400 bg-clip-text text-transparent hover:scale-105 transition-transform duration-300">
        Portfolio
      </a>

      {/* Desktop Menu */}
      <div class="hidden md:flex space-x-1">
        {
          [
            { path: '/', name: 'Home' },
            { path: '/about', name: 'About' },
            { path: '/stack', name: 'Tech Stack' },  
            { path: '/projects', name: 'Projects' },
            { path: '/certificates', name: 'Certificates' },
            { path: '/contact', name: 'Contact' }
          ].map((item) => (
            <a
              href={item.path}
              class={`
                relative px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300
                hover:scale-105 hover:shadow-lg
                ${currentPage === item.path
                  ? 'text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-950/50'
                  : 'text-gray-700 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/30'
                }
              `}
            >
              {item.name}
              {currentPage === item.path && (
                <span class="absolute bottom-0 left-1/2 transform -translate-x-1/2 w-6 h-0.5 bg-red-500 rounded-full"></span>
              )}
            </a>
          ))
        }
      </div>

      {/* Right side: Theme Toggle & Mobile Menu Button */}
      <div class="flex items-center space-x-2">
        <ThemeToggle client:load />
        
        {/* Mobile Menu Button */}
        <button
          id="mobile-menu-button"
          class="md:hidden p-2 rounded-xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-all duration-300 hover:scale-105"
          aria-label="Menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    {/* Mobile Menu */}
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      {
        [
          { path: '/', name: 'Home' },
          { path: '/about', name: 'About' },
          { path: '/projects', name: 'Projects' },
          { path: '/certificates', name: 'Certificates' },
          { path: '/contact', name: 'Contact' }
        ].map((item) => (
          <a
            href={item.path}
            class={`
              block px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300
              hover:scale-105 hover:translate-x-1
              ${currentPage === item.path
                ? 'text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-950/50'
                : 'text-gray-700 dark:text-gray-300 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/30'
              }
            `}
          >
            {item.name}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle - ringan, tanpa library
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  
  if (button && menu) {
    button.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>