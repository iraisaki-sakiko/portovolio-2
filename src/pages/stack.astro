---
import Layout from '../layouts/Layout.astro';
import GlassCard from '../components/GlassCard.astro';

// Data keahlian dengan logo, persentase, dan warna
const skills = [
  {
    name: "Python",
    percentage: 50,
    logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg",
    color: "#3776AB",
    lightColor: "#FFD43B",
    description: "Automation, Telegram Bots, Cybersecurity Tools"
  },
  {
    name: "Node.js",
    percentage: 60,
    logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/nodejs/nodejs-original.svg",
    color: "#339933",
    lightColor: "#68A063",
    description: "Backend Development, REST APIs, Real-time Apps"
  },
  {
    name: "HTML",
    percentage: 70,
    logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg",
    color: "#E34F26",
    lightColor: "#F06529",
    description: "Semantic HTML, Accessibility, SEO Structure"
  },
  {
    name: "CSS",
    percentage: 59,
    logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg",
    color: "#1572B6",
    lightColor: "#33A9DC",
    description: "Flexbox, Grid, Animations, Responsive Design"
  },
  {
    name: "JavaScript",
    percentage: 68,
    logo: "https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg",
    color: "#F7DF1E",
    lightColor: "#F7DF1E",
    description: "ES6+, Async/Await, DOM Manipulation, APIs"
  }
];
---

<Layout title="Tech Stack | My Skills" description="My technical skills and expertise in various technologies">
  <div class="max-w-4xl mx-auto">
    {/* Header */}
    <div class="text-center mb-12 animate-fade-in-down">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 bg-gradient-to-r from-red-600 to-red-400 bg-clip-text text-transparent">
        Tech Stack
      </h1>
      <p class="text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        My technical expertise and proficiency levels in various technologies
      </p>
    </div>

    {/* Skills Grid */}
    <div class="space-y-6">
      {skills.map((skill, index) => (
        <div 
          class="animate-fade-in-up" 
          style={`animation-delay: ${index * 0.1}s`}
        >
          <GlassCard class="p-6 hover:shadow-2xl transition-all duration-500">
            <div class="flex flex-col md:flex-row md:items-center gap-6">
              {/* Logo & Info */}
              <div class="flex items-center gap-4 md:w-1/3">
                <div class="w-16 h-16 rounded-2xl bg-white dark:bg-gray-800 p-3 shadow-lg flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                  <img 
                    src={skill.logo} 
                    alt={skill.name}
                    class="w-full h-full object-contain"
                    loading="lazy"
                  />
                </div>
                <div>
                  <h3 class="text-xl font-bold text-gray-800 dark:text-white">
                    {skill.name}
                  </h3>
                  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                    {skill.description}
                  </p>
                </div>
              </div>

              {/* Progress Bar */}
              <div class="flex-1 space-y-2">
                <div class="flex justify-between items-center text-sm">
                  <span class="text-gray-600 dark:text-gray-400">Proficiency</span>
                  <span class="font-mono font-bold" style={`color: ${skill.color}`}>
                    <span id={`percent-${index}`}>0</span>%
                  </span>
                </div>
                <div class="relative h-4 bg-gray-200 dark:bg-gray-700 rounded-full overflow-hidden">
                  <div 
                    id={`bar-${index}`}
                    class="absolute left-0 top-0 h-full rounded-full transition-all duration-1000 ease-out"
                    style={`width: 0%; background: linear-gradient(90deg, ${skill.color}, ${skill.lightColor});`}
                  ></div>
                </div>
                
                {/* Skill Level Tag */}
                <div class="flex justify-end">
                  <span 
                    class="text-xs px-2 py-1 rounded-full"
                    style={`background: ${skill.color}20; color: ${skill.color};`}
                  >
                    {skill.percentage >= 70 ? "Advanced" : skill.percentage >= 50 ? "Intermediate" : "Beginner"}
                  </span>
                </div>
              </div>
            </div>
          </GlassCard>
        </div>
      ))}
    </div>

    {/* Note Section */}
    <div class="mt-12 text-center animate-fade-in-up" style="animation-delay: 0.6s">
      <GlassCard class="p-4">
        <p class="text-sm text-gray-500 dark:text-gray-400">
          💡 <strong>Interactive Progress Bars</strong> — Watch the bars fill up to match my actual skill levels!
        </p>
      </GlassCard>
    </div>
  </div>
</Layout>

<script>
  // Interactive progress bars animation
  (function() {
    const skills = [
      { percentage: 50 },
      { percentage: 60 },
      { percentage: 70 },
      { percentage: 59 },
      { percentage: 68 }
    ];

    function animateBars() {
      skills.forEach((skill, index) => {
        const bar = document.getElementById(`bar-${index}`);
        const percentText = document.getElementById(`percent-${index}`);
        
        if (bar && percentText) {
          let currentPercent = 0;
          const targetPercent = skill.percentage;
          const duration = 1500; // 1.5 detik
          const stepTime = 20; // 20ms per step
          const steps = duration / stepTime;
          const increment = targetPercent / steps;
          
          const timer = setInterval(() => {
            currentPercent += increment;
            if (currentPercent >= targetPercent) {
              currentPercent = targetPercent;
              clearInterval(timer);
            }
            
            const displayPercent = Math.floor(currentPercent);
            bar.style.width = `${displayPercent}%`;
            percentText.textContent = displayPercent;
          }, stepTime);
        }
      });
    }

    // Intersection Observer untuk memulai animasi saat elemen terlihat
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          animateBars();
          observer.disconnect(); // Hanya jalankan sekali
        }
      });
    }, { threshold: 0.2 });

    // Observer container utama
    const container = document.querySelector('.max-w-4xl');
    if (container) {
      observer.observe(container);
    } else {
      // Fallback: jalanin langsung setelah halaman load
      window.addEventListener('load', () => {
        setTimeout(animateBars, 500);
      });
    }
  })();
</script>

<style is:global>
  /* Additional styles for smooth animations */
  .transition-all {
    transition-property: all;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .duration-1000 {
    transition-duration: 1000ms;
  }
  
  .ease-out {
    transition-timing-function: cubic-bezier(0, 0, 0.2, 1);
  }
</style>